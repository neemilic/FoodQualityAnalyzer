<Window x:Class="FoodQualityAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FoodQualityAnalyzer"
        mc:Ignorable="d" 
        Title="MainWindow" Height="550" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Группа выбора продуктов -->
        <GroupBox Header="Выберите продукты" 
                  Grid.Row="0" 
                  Margin="0,0,0,10"
                  Padding="5">
            <ScrollViewer MaxHeight="450">
                <StackPanel x:Name="ProductsPanel" Margin="5"/>
            </ScrollViewer>
        </GroupBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Формат отчёта:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
            <ComboBox x:Name="FormatComboBox"
                      Width="120"
                      FontSize="13"
                      SelectionChanged="FormatComboBox_SelectionChanged">
                <ComboBoxItem Content="JSON" IsSelected="True"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>
        </StackPanel>
        <!-- Кнопка "Показать качество" -->
        <Button x:Name="ShowQualityButton" 
                Grid.Row="2"
                Content="Показать качество"
                Height="40"
                Margin="0,10"
                FontSize="14"
                IsEnabled="False"
                Click="ShowQualityButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#4CAF50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#CCCCCC"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#45a049"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Информационная метка -->

    </Grid>
</Window>
